<?xml version="1.0" encoding="UTF-8"?>
<!--
  IKE Community — Parent POM
  ═══════════════════════════

  The standard parent for all IKE Community projects. Inheriting this
  POM provides two things through a single <parent> declaration:

    1. Build conventions: Java 25 compiler configuration, ASM 9.9 for
       annotation processing, surefire/failsafe with JPMS add-opens,
       GPG signing with Bouncy Castle, platform classifier profiles,
       enforcer rules, and the AsciiDoc documentation pipeline (activated
       when src/docs/asciidoc exists). Inherited from ike-pipeline.

    2. Dependency version management — centralized <dependencyManagement>
       entries for IKE infrastructure artifacts (ike-build-standards,
       ike-doc-resources, ike-build-tools), shared test dependencies
       (JUnit 5, AssertJ, Mockito), and workspace-specific BOMs as
       the ecosystem grows.

  Usage (inheritance — recommended):

    <parent>
        <groupId>network.ike</groupId>
        <artifactId>ike-parent</artifactId>
        <version>1.1.0</version>
    </parent>

  Usage (import only — for projects that inherit a different parent):

    <dependencyManagement>
        <dependencies>
            <dependency>
                <groupId>network.ike</groupId>
                <artifactId>ike-parent</artifactId>
                <version>1.1.0</version>
                <type>pom</type>
                <scope>import</scope>
            </dependency>
        </dependencies>
    </dependencyManagement>
-->
<project xmlns="http://maven.apache.org/POM/4.1.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.1.0
         http://maven.apache.org/xsd/maven-4.1.0.xsd">
    <modelVersion>4.1.0</modelVersion>

    <parent>
        <groupId>network.ike</groupId>
        <artifactId>ike-pipeline</artifactId>
    </parent>

    <artifactId>ike-parent</artifactId>
    <packaging>pom</packaging>

    <name>IKE Parent</name>
    <description>
        Standard parent POM for IKE Community projects. Provides build
        conventions (Java 25 compiler, test harness, GPG signing, and the
        AsciiDoc documentation pipeline) together with centralized dependency
        version management — combining the roles of a traditional parent POM
        and a bill-of-materials (BOM) in a single artifact. Projects that
        cannot inherit may import this POM with scope=import for dependency
        version alignment only.
    </description>
    <url>https://github.com/IKE-Network/ike-pipeline</url>
    <inceptionYear>2026</inceptionYear>

    <licenses>
        <license>
            <name>Apache License, Version 2.0</name>
            <url>https://www.apache.org/licenses/LICENSE-2.0.txt</url>
            <distribution>repo</distribution>
        </license>
    </licenses>

    <organization>
        <name>IKE Community</name>
        <url>https://ike.network</url>
    </organization>

    <distributionManagement>
        <repository>
            <id>ike-releases</id>
            <url>${deploy.release.url}</url>
        </repository>
        <snapshotRepository>
            <id>ike-snapshots</id>
            <url>${deploy.snapshot.url}</url>
        </snapshotRepository>
        <site>
            <id>ike-site</id>
            <url>scpexe://proxy/srv/ike-site/ike-pipeline/${project.artifactId}</url>
        </site>
    </distributionManagement>

    <!-- ════════════════════════════════════════════════════════════════ -->
    <!-- Dependency Management — IKE infrastructure + test dependencies. -->
    <!-- Workspace BOMs (Tinkar, Komet, JavaFX, ELK) added here as the  -->
    <!-- ecosystem grows.                                                -->
    <!-- ════════════════════════════════════════════════════════════════ -->
    <dependencyManagement>
        <dependencies>
            <!-- IKE Build Standards (Claude instruction files) -->
            <dependency>
                <groupId>network.ike</groupId>
                <artifactId>ike-build-standards</artifactId>
                <version>${project.version}</version>
                <classifier>claude</classifier>
                <type>zip</type>
            </dependency>

            <!-- IKE Build Standards (human-readable convention documents) -->
            <dependency>
                <groupId>network.ike</groupId>
                <artifactId>ike-build-standards</artifactId>
                <version>${project.version}</version>
                <classifier>docs</classifier>
                <type>zip</type>
            </dependency>

            <!-- IKE Build Tools (shared scripts, release automation) -->
            <dependency>
                <groupId>network.ike</groupId>
                <artifactId>ike-build-tools</artifactId>
                <version>${project.version}</version>
                <classifier>tools</classifier>
                <type>zip</type>
            </dependency>

            <!-- IKE Documentation Resources (themes, assembly descriptors, configs) -->
            <dependency>
                <groupId>network.ike</groupId>
                <artifactId>ike-doc-resources</artifactId>
                <version>${project.version}</version>
            </dependency>
        </dependencies>
    </dependencyManagement>

    <build>
        <pluginManagement>
            <plugins>
                <plugin><artifactId>maven-clean-plugin</artifactId><version>3.4.0</version></plugin>
                <plugin><artifactId>maven-install-plugin</artifactId><version>3.1.3</version></plugin>
                <plugin><artifactId>maven-deploy-plugin</artifactId><version>3.1.3</version></plugin>
            </plugins>
        </pluginManagement>
    </build>
</project>
